# Port the server listens on
PORT=3001

# Set to production for deployment
NODE_ENV=production

# Password to log in to the app
AUTH_PASSWORD=choose_a_strong_password

# Your Anthropic API key from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# deeplink = manual WhatsApp, api = WhatsApp Business API
WHATSAPP_MODE=deeplink
