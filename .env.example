# Port the server listens on
PORT=3001

# Set to production for deployment
NODE_ENV=production

# Password to log in to the app
AUTH_PASSWORD=choose_a_strong_password

# Your Anthropic API key from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# deeplink = manual WhatsApp, api = WhatsApp Business API
WHATSAPP_MODE=deeplink

# Calendly personal access token (from app.calendly.com → Integrations → API & Webhooks)
CALENDLY_TOKEN=your_calendly_personal_access_token

# Calendly booking links (used by the settings page and WhatsApp templates)
CALENDLY_FOLLOWUP_LINK=https://calendly.com/nm-nutritionist1/30-minute-meeting-clone
CALENDLY_FIRST_LINK=https://calendly.com/nm-nutritionist1/30min
